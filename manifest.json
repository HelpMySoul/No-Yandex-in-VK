{
  "manifest_version": 3,
  "name": "VK Invite Promo Blocker",
  "version": "1.0.0",
  "description": "Removes and blocks #l_invite_promo on vk.com and vk.ru",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "VK Invite Promo Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://vk.com/*",
        "*://vk.ru/*",
        "*://*.vk.com/*",
        "*://*.vk.ru/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
